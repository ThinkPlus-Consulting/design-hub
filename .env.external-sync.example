# Design Hub external-sync example values.
# Copy these into your local shell env or a private, ignored env file before starting the backend.
#
# Important:
# - Jira now supports direct Jira Cloud polling when base-url, account email, token, and poll-path are set.
# - Azure DevOps still expects an adapter endpoint that accepts the query params shown below.
# - A plain Azure Portal URL is not enough by itself to satisfy Azure poll-path configuration.

# Shared scheduler defaults
DESIGNHUB_EXTERNAL_SYNC_SCHEDULER_FIXED_DELAY=PT15M
DESIGNHUB_EXTERNAL_SYNC_SCHEDULER_REQUESTED_BY=manual-local

# Jira
DESIGNHUB_EXTERNAL_SYNC_JIRA_BASE_URL=https://thinkplus.atlassian.net
DESIGNHUB_EXTERNAL_SYNC_JIRA_PROJECT_KEY=DPAA
DESIGNHUB_EXTERNAL_SYNC_JIRA_ACCOUNT_EMAIL=info@thinkplus.ae
DESIGNHUB_EXTERNAL_SYNC_JIRA_TOKEN=
DESIGNHUB_EXTERNAL_SYNC_JIRA_POLL_PATH=/rest/api/3/search/jql
DESIGNHUB_EXTERNAL_SYNC_JIRA_POLLING_INTERVAL=PT15M
DESIGNHUB_EXTERNAL_SYNC_JIRA_POLLING_DRY_RUN=true
DESIGNHUB_EXTERNAL_SYNC_JIRA_JQL=project = DPAA ORDER BY updated DESC
DESIGNHUB_EXTERNAL_SYNC_JIRA_UPDATED_SINCE=
DESIGNHUB_EXTERNAL_SYNC_JIRA_WEBHOOK_SECRET=

# Azure DevOps
# Current Azure polling still expects an adapter route rather than raw Azure Portal URLs.
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_BASE_URL=
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_ORGANIZATION=
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_PROJECT=
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_TOKEN=
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_POLL_PATH=
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_POLLING_INTERVAL=PT15M
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_POLLING_DRY_RUN=true
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_WIQL=Select [System.Id] From WorkItems Order By [System.ChangedDate] Desc
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_UPDATED_SINCE=
DESIGNHUB_EXTERNAL_SYNC_AZURE_DEVOPS_WEBHOOK_SECRET=
